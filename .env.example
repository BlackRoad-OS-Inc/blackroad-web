# Service Configuration
SERVICE_NAME=blackroad-os-web
SERVICE_ENV=development
SERVICE_VERSION=0.0.1

# Next.js Public Variables
NEXT_PUBLIC_APP_NAME=BlackRoad OS
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# BlackRoad Core Gateway (tokenless AI provider proxy)
# Points to blackroad-core running at :8787
NEXT_PUBLIC_GATEWAY_URL=http://127.0.0.1:8787

# BlackRoad Agents Registry API
# Points to blackroad-agents registry service
NEXT_PUBLIC_AGENTS_API_URL=http://127.0.0.1:3001

# Optional: Build metadata
BUILD_TIME=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

